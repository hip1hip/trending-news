# Docker Compose 가 프로젝트 루트의 .env 를 자동 로드합니다.
# 복사: copy .env.example .env (또는 cp) 후 비밀번호·웹훅을 반드시 변경하세요.
# POSTGRES_PASSWORD 와 DATABASE_URL 의 비밀번호 부분은 반드시 동일해야 합니다.

POSTGRES_USER=trending
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=trending

# asyncpg URL (호스트명은 compose 서비스명 db)
DATABASE_URL=postgresql+asyncpg://trending:change-me-to-a-long-random-string@db:5432/trending

# Discord Incoming Webhook 전체 URL (저장소·이슈에 붙여넣지 말 것)
DISCORD_WEBHOOK_URL=

# 스케줄러 타임존 (월·수·금 08:00)
SCHEDULER_TZ=Asia/Seoul
